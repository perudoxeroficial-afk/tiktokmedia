{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "apt-get update -y",
        "apt-get install -y nodejs npm"
      ]
    },
    "build": {
      "commands": ["npm install --prefix toby_lab"]
    }
  },
  "deploy": {
    "aptPackages": ["ffmpeg", "nodejs"]
  }
}
